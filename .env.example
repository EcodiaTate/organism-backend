# ═══════════════════════════════════════════════════════════════════════════════
# EcodiaOS Environment Variables — Complete Reference
# ═══════════════════════════════════════════════════════════════════════════════
#
# All variables used throughout the EcodiaOS backend codebase.
# Copy this file to .env and fill in YOUR values.
# Variables marked [REQUIRED] must be set for startup.
# Variables marked [CHILD-ONLY] are set automatically at spawn time.
# Variables marked [TRAINING-ONLY] are only needed if running RE/Simula training.
#
# ═══════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────────
# INFRASTRUCTURE: Neo4j (Knowledge Graph) [REQUIRED]
# ──────────────────────────────────────────────────────────────────────────────
ECODIAOS_NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
ECODIAOS_NEO4J_USERNAME=neo4j
ECODIAOS_NEO4J_PASSWORD=your_neo4j_password
ECODIAOS_NEO4J_DATABASE=neo4j

# ──────────────────────────────────────────────────────────────────────────────
# INFRASTRUCTURE: TimescaleDB (Time-Series) [REQUIRED for Soma interoception]
# ──────────────────────────────────────────────────────────────────────────────
ECODIAOS_TIMESCALEDB__HOST=localhost
ECODIAOS_TIMESCALEDB__PORT=5432
ECODIAOS_TIMESCALEDB__DATABASE=ecodiaos
ECODIAOS_TIMESCALEDB__USERNAME=postgres
ECODIAOS_TSDB_PASSWORD=your_timescaledb_password
ECODIAOS_TIMESCALEDB__SSL=false

# ──────────────────────────────────────────────────────────────────────────────
# INFRASTRUCTURE: Redis (Event Bus & Caching) [REQUIRED]
# ──────────────────────────────────────────────────────────────────────────────
ECODIAOS_REDIS__URL=rediss://your-redis-host:6379/0
ECODIAOS_REDIS_PASSWORD=your_redis_password
REDIS_KEY_PREFIX=ecodiaos

# ──────────────────────────────────────────────────────────────────────────────
# LLM CONFIGURATION: Primary Reasoning [REQUIRED]
# ──────────────────────────────────────────────────────────────────────────────
ECODIAOS_LLM__PROVIDER=anthropic
ECODIAOS_LLM__MODEL=claude-opus-4-6
ECODIAOS_LLM_API_KEY=sk-ant-your_anthropic_api_key
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# Fallback/Secondary LLM
OPENAI_API_KEY=sk-proj-your_openai_api_key

# ──────────────────────────────────────────────────────────────────────────────
# LLM CONFIGURATION: Reasoning Engine (RE) [REQUIRED if RE_ENABLED=true]
# ──────────────────────────────────────────────────────────────────────────────
ECODIAOS_RE_ENABLED=true
ECODIAOS_RE_VLLM_URL=http://localhost:8001/v1
ECODIAOS_RE_MODEL=ecodiaos-reasoning
ECODIAOS_RE_TRAINING_EXPORT_DIR=data/re_training_batches

# ──────────────────────────────────────────────────────────────────────────────
# LLM CONFIGURATION: Simula (Self-Evolution Engine)
# ──────────────────────────────────────────────────────────────────────────────
SIMULA_MODE=local
SIMULA_LLM_MODEL=claude-sonnet-4-6
ECODIAOS_SIMULA__THINKING_MODEL_API_KEY=sk-...  # For Stage 1 thinking
ECODIAOS_SIMULA__EMBEDDING_API_KEY=pa-...  # Embedding model API key
ECODIAOS_SIMULA__LEAN_PROJECT_PATH=/path/to/lean/project
ECODIAOS_SIMULA__GRPO_GPU_IDS=0,1

# ──────────────────────────────────────────────────────────────────────────────
# INSTANCE & IDENTITY [REQUIRED]
# ──────────────────────────────────────────────────────────────────────────────
ECODIAOS_INSTANCE_ID=genesis-001
ECODIAOS_IS_GENESIS_NODE=true
ECODIAOS_VAULT_PASSPHRASE=your_vault_passphrase_32chars_min

# ──────────────────────────────────────────────────────────────────────────────
# CONFIGURATION PATHS [REQUIRED]
# ──────────────────────────────────────────────────────────────────────────────
ECODIAOS_CONFIG_PATH=config/default.yaml
ECODIAOS_SEED_PATH=config/seeds/example_seed.yaml
ECODIAOS_PERCEPTS_DIR=config/percepts

# ──────────────────────────────────────────────────────────────────────────────
# CHILD INSTANCE CONFIGURATION [CHILD-ONLY - Set at spawn time]
# ──────────────────────────────────────────────────────────────────────────────
# ECODIAOS_PARENT_INSTANCE_ID=genesis-001
# ECODIAOS_BIRTH_CERTIFICATE=cert_pem_string
# ECODIAOS_GENESIS_CA_CERT=ca_cert_pem_string
# ECODIAOS_WALLET_ADDRESS=0xYourChildWalletAddress
# ECODIAOS_NICHE=research_niche_01
# ECODIAOS_NICHE_NAME=Research Specialist
# ECODIAOS_NICHE_DESCRIPTION=Specialized analysis and discovery
# ECODIAOS_FEDERATION_ADDRESS=http://parent-instance:8000

# ──────────────────────────────────────────────────────────────────────────────
# GENOME INHERITANCE [CHILD-ONLY - Injected at spawn]
# ──────────────────────────────────────────────────────────────────────────────
# ECODIAOS_BELIEF_GENOME_ID=genome-uuid
# ECODIAOS_BELIEF_GENOME_PAYLOAD={}
# ECODIAOS_SIMULA_GENOME_ID=genome-uuid
# ECODIAOS_SIMULA_GENOME_PAYLOAD={}
# ECODIAOS_AXON_GENOME_PAYLOAD={}
# ECODIAOS_EQUOR_GENOME_PAYLOAD={}
# ECODIAOS_TELOS_GENOME_PAYLOAD={}
# ECODIAOS_SOMA_GENOME_PAYLOAD={}

# ──────────────────────────────────────────────────────────────────────────────
# SIMULA MONITORING & EXECUTION
# ──────────────────────────────────────────────────────────────────────────────
SIMULA_PROACTIVE_INTERVAL_S=300
SIMULA_GOAL_AUDIT_INTERVAL_S=600
SIMULA_PROACTIVE_DRY_RUN=false

# ──────────────────────────────────────────────────────────────────────────────
# SKIA: Resilience & State Backup
# ──────────────────────────────────────────────────────────────────────────────
ECODIAOS_SKIA__ENABLED=true
ECODIAOS_SKIA__PINATA_JWT=your_pinata_jwt
ECODIAOS_SKIA__GCP_PROJECT_ID=ecodiaos
ECODIAOS_SKIA__GCP_SERVICE_NAME=ecodiaos-core
ECODIAOS_SKIA__GCP_SERVICE_ACCOUNT_KEY_B64=base64_encoded_gcp_key
ECODIAOS_SKIA_RESTORE_CID=  # IPFS CID for state restoration

# Degradation tracking
DEGRADATION_MEMORY_DECAY_RATE=0.98
DEGRADATION_CONFIG_DRIFT_RATE=0.02
DEGRADATION_HYPOTHESIS_STALENESS_RATE=0.05
DEGRADATION_TICK_INTERVAL_S=60

# ──────────────────────────────────────────────────────────────────────────────
# WALLET & FINANCE [REQUIRED for Oikos economic metabolism]
# ──────────────────────────────────────────────────────────────────────────────
ECODIAOS_WALLET__CDP_API_KEY_ID=your_cdp_api_key_id
ECODIAOS_WALLET__CDP_API_KEY_SECRET=your_cdp_api_secret
ECODIAOS_WALLET__CDP_WALLET_SECRET=your_cdp_wallet_secret
ECODIAOS_WALLET__NETWORK=base-mainnet
ECODIAOS_WALLET__ACCOUNT_NAME=default
ECODIAOS_WALLET__SEED_FILE_PATH=/path/to/seed.json
EOS_CAPITAL_BASE_USD=10
EOS_DAILY_BUDGET_FLOOR_USD=1.00
EOS_SURVIVAL_RESERVE_USD=100

# Blockchain RPC
ECODIAOS_MEV__RPC_URL=https://base-mainnet.g.alchemy.com/v2/your_alchemy_key

# ──────────────────────────────────────────────────────────────────────────────
# EQUOR & GOVERNANCE
# ──────────────────────────────────────────────────────────────────────────────
ECODIAOS_OIKOS__IS_GENESIS_NODE=true
EOS_HITL_CAPITAL_THRESHOLD=500  # Capital threshold for human escalation

# ──────────────────────────────────────────────────────────────────────────────
# NOVA: Active Inference
# ──────────────────────────────────────────────────────────────────────────────
ECODIAOS_NOVA__HEARTBEAT_INTERVAL_SECONDS=30
ECODIAOS_NOVA__HUNGER_BALANCE_THRESHOLD_USD=100.0

# ──────────────────────────────────────────────────────────────────────────────
# MONITORING & ALERTING
# ──────────────────────────────────────────────────────────────────────────────
EOS_ESCALATION_WEBHOOK=https://your-webhook-endpoint/incidents
EOS_TELEGRAM_BOT_TOKEN=your_telegram_bot_token
EOS_TELEGRAM_CHAT_ID=your_telegram_chat_id

# ──────────────────────────────────────────────────────────────────────────────
# IDENTITY: HITL & Communication
# ──────────────────────────────────────────────────────────────────────────────
ECODIAOS_IDENTITY_COMM__TWILIO_ACCOUNT_SID=AC...
ECODIAOS_IDENTITY_COMM__TWILIO_AUTH_TOKEN=your_twilio_auth_token
ECODIAOS_IDENTITY_COMM__TWILIO_FROM_NUMBER=+61485027195
ECODIAOS_IDENTITY_COMM__ADMIN_PHONE_NUMBER=+61404247153
ECODIAOS_IDENTITY_API__TWILIO_ACCOUNT_SID=SK...
ECODIAOS_IDENTITY_API__TWILIO_AUTH_TOKEN=your_twilio_api_token

# ──────────────────────────────────────────────────────────────────────────────
# EXTERNAL INTEGRATIONS & CONNECTORS
# ──────────────────────────────────────────────────────────────────────────────
ECODIAOS_EXTERNAL_PLATFORMS__GITHUB_TOKEN=ghp_your_github_token
GITHUB_TOKEN=ghp_your_github_token
GH_TOKEN=ghp_your_github_token
ECODIAOS_EXTERNAL_PLATFORMS__ALGORA_API_KEY=your_algora_api_key
ECODIAOS_CONNECTORS__LINKEDIN__CLIENT_ID=your_linkedin_client_id
ECODIAOS_CONNECTORS__LINKEDIN__CLIENT_SECRET=your_linkedin_client_secret

# ──────────────────────────────────────────────────────────────────────────────
# MONETIZATION
# ──────────────────────────────────────────────────────────────────────────────
TOLLBOOTH_WEBHOOK_SECRET=your_tollbooth_webhook_secret

# ──────────────────────────────────────────────────────────────────────────────
# REASONING ENGINE TRAINING [TRAINING-ONLY]
# ──────────────────────────────────────────────────────────────────────────────
RE_BASE_MODEL=Qwen/Qwen3-8B
RE_TRAINING_S3_BUCKET=ecodiaos-re-training
RE_TRAINING_S3_PREFIX=batches/
RE_TRAINING_EXPORT_DIR=data/re_training_batches
RE_TRAINING_TIMEOUT_S=7200
RE_RED_TEAM_PROMPTS_PATH=config/red_team_prompts.jsonl

# DPO Training
DPO_DATA=data/re_training_batches/dpo_pairs.jsonl
DPO_BETA=0.1
TRAINING_MODE=dpo
MIN_DPO_PAIRS=50
BASE_ADAPTER=
OUTPUT_DIR=data/re_adapters/dpo/latest

# ──────────────────────────────────────────────────────────────────────────────
# SIMULA TRAINING [TRAINING-ONLY]
# ──────────────────────────────────────────────────────────────────────────────
DATASET_CID=  # IPFS CID of training dataset
PINATA_JWT=  # Pinata JWT for IPFS access
PINATA_GATEWAY_URL=https://gateway.pinata.cloud
TRAINING_ARGS={}
STATUS_PORT=8080
PREVIOUS_ADAPTER_PATH=
PROMPTS_PATH=data/re_training_batches/anchor_prompts.jsonl

# ──────────────────────────────────────────────────────────────────────────────
# WEIGHTS & BIASES (W&B) - Training Tracking [TRAINING-ONLY]
# ──────────────────────────────────────────────────────────────────────────────
WANDB_API_KEY=wandb_v1_your_key
WANDB_PROJECT=ecodiaos-reasoning
WANDB_ENTITY=ecodia-org
WANDB_RUN_NAME=auto-generated
WANDB_JOB_TYPE=tier2_sft

# ──────────────────────────────────────────────────────────────────────────────
# HUGGINGFACE - Model Hub
# ──────────────────────────────────────────────────────────────────────────────
HUGGING_FACE_HUB_TOKEN=hf_your_hf_token
HF_MODEL_REPO=

# ──────────────────────────────────────────────────────────────────────────────
# AWS - Bedrock & Cloud Services [If using Bedrock]
# ──────────────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# ──────────────────────────────────────────────────────────────────────────────
# RUNPOD - Compute Infrastructure [If using RunPod]
# ──────────────────────────────────────────────────────────────────────────────
RUNPOD_POD_ID=your_runpod_pod_id
RUNPOD_API_KEY=rpa_your_runpod_api_key

# ──────────────────────────────────────────────────────────────────────────────
# SERVER & API Configuration
# ──────────────────────────────────────────────────────────────────────────────
ECODIAOS_API_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
ECODIAOS_CODEBASE_ROOT=/path/to/ecodiaos/backend

# ──────────────────────────────────────────────────────────────────────────────
# TESTING & DEBUGGING [Testbed Only]
# ──────────────────────────────────────────────────────────────────────────────
# SERVICE_C_URL=http://service-c:9090/db/query
# LISTEN_PORT=8080

# ═══════════════════════════════════════════════════════════════════════════════
# STARTUP REQUIREMENTS CHECKLIST
# ═══════════════════════════════════════════════════════════════════════════════
#
# GENESIS NODE (REQUIRED to start):
#   [ ] ECODIAOS_NEO4J_* (database)
#   [ ] ECODIAOS_TIMESCALEDB_* (time-series)
#   [ ] ECODIAOS_REDIS__URL (event bus)
#   [ ] ECODIAOS_LLM__PROVIDER + LLM API key
#   [ ] ECODIAOS_INSTANCE_ID + ECODIAOS_IS_GENESIS_NODE=true
#   [ ] ECODIAOS_CONFIG_PATH + ECODIAOS_SEED_PATH
#   [ ] ECODIAOS_VAULT_PASSPHRASE
#   [ ] Wallet credentials (if using Oikos)
#
# CHILD NODE (Auto-injected at spawn):
#   - Parent sets all ECODIAOS_*_GENOME_* and ECODIAOS_PARENT_* vars
#   - Child inherits genome and initializes from parent's constitution
#
# TRAINING MODES:
#   - RE Training: Set RE_BASE_MODEL, DPO_DATA, OUTPUT_DIR
#   - Simula Training: Set DATASET_CID, PINATA_JWT, SIMULA_LLM_MODEL
#   - W&B tracking: Set WANDB_API_KEY (optional, logs to W&B if present)
#
# ═══════════════════════════════════════════════════════════════════════════════
